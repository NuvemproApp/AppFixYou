# ────────────────────────────────────────────────────────────────────────────
# NuvemPro Admin Frontend — Environment Variables
#
# PRIMÁRIO: Use o Doppler CLI — nenhum arquivo .env necessário.
#   Setup:  doppler setup  (executar uma vez neste diretório)
#   Rodar:  doppler run -- npm run dev
#
# ALTERNATIVO: Copie este arquivo para .env e preencha os valores.
#   cp .env.example .env
#
# NOTA: Em desenvolvimento local, VITE_ADMIN_API_URL pode ficar vazio.
#       O vite.config.js já faz proxy de /admin-api → http://localhost:3001.
#       Defina apenas em produção (URL do Railway).
# ────────────────────────────────────────────────────────────────────────────

VITE_ADMIN_API_URL=
