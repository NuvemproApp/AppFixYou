{
  "name": "nuvempro-app-backend",
  "version": "1.0.0",
  "scripts": {
    "dev": "nodemon src/server.js",
    "build": "npx prisma generate && npx prisma migrate deploy",
    "start": "node src/server.js",
    "test": "node --test src/__tests__/*.test.js",
    "db:push": "npx prisma db push",
    "db:generate": "npx prisma generate",
    "db:seed": "node prisma/seed-admin.js",
    "db:studio": "npx prisma studio",
    "build:script": "npx terser public/app.js --compress passes=3,drop_console=false,pure_getters=true --mangle toplevel=false --comments false --output public/app.min.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1085.0",
    "@aws-sdk/s3-request-presigner": "^3.1085.0",
    "@prisma/client": "^6.0.0",
    "axios": "^1.16.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.0",
    "multer": "^2.2.0",
    "stripe": "^17.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "prisma": "^6.19.2",
    "terser": "^5.48.0"
  },
  "overrides": {
    "lodash": "^4.18.0",
    "form-data": "^4.0.6",
    "defu": "^6.1.5",
    "effect": "^3.20.0"
  },
  "engines": {
    "node": "22.x"
  }
}
