# ────────────────────────────────────────────────────────────────────────────
# NuvemPro Backend — Environment Variables
#
# PRIMÁRIO: Use o Doppler CLI — nenhum arquivo .env necessário.
#   Instalar:  https://docs.doppler.com/docs/install-cli
#   Setup:     doppler setup          (executar uma vez neste diretório)
#   Rodar:     doppler run -- npm run dev
#
# ALTERNATIVO: Copie este arquivo para .env e preencha os valores.
#   cp .env.example .env
# ────────────────────────────────────────────────────────────────────────────

# ─── Database
DATABASE_URL=postgresql://user:pass@localhost:5432/myapp_dev

# ─── App
NODE_ENV=development
PORT=3001
APP_NAME=MeuApp
APP_SLUG=meuapp
APP_EMAIL=contato@meuapp.com
TRIAL_DAYS=7

# ─── Segurança (gere com: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_openssl_rand_hex_32
ADMIN_JWT_SECRET=CHANGE_ME_openssl_rand_hex_32

# ─── Nuvemshop OAuth (painel de parceiros: partners.nuvemshop.com.br)
NUVEMSHOP_APP_ID=00000
NUVEMSHOP_CLIENT_ID=00000
NUVEMSHOP_CLIENT_SECRET=CHANGE_ME

# ─── Stripe
# Modo test/live é alternado no admin (Planos → toggle); o flag fica no banco
# (AdminConfig.stripe_mode). As chaves abaixo ficam SEMPRE no env, nunca no banco.
# Configure as duas para poder alternar; o app usa a do modo ativo.
STRIPE_SECRET_KEY_TEST=sk_test_CHANGE_ME
STRIPE_SECRET_KEY_LIVE=sk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET_TEST=whsec_CHANGE_ME
STRIPE_WEBHOOK_SECRET_LIVE=whsec_CHANGE_ME

# Legado (fallback): usado quando as chaves *_TEST/*_LIVE acima não estão setadas.
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# ─── GitHub — checagem de atualização do template (admin → Configurações)
# Token com permissão de LEITURA do repositório do template (privado).
# Sem ele, "Versão mais recente" fica indisponível. Use um PAT (classic: scope repo,
# ou fine-grained: read em Contents/Metadata do repo do template).
GITHUB_TOKEN=

# ─── Stripe Price IDs (preenchidos automaticamente após sync no admin)
STRIPE_PRICE_GROWTH_MONTHLY=
STRIPE_PRICE_GROWTH_SEMESTRAL=
STRIPE_PRICE_GROWTH_ANNUAL=
STRIPE_PRICE_SCALE_MONTHLY=
STRIPE_PRICE_SCALE_SEMESTRAL=
STRIPE_PRICE_SCALE_ANNUAL=

# ─── URLs (dev: localhost | produção: URLs reais dos deploys)
FRONTEND_URL=http://localhost:5173
ADMIN_FRONTEND_URL=http://localhost:5174

# ─── Admin seed (usado por prisma/seed-admin.js)
ADMIN_SEED_EMAIL=admin@meuapp.com
ADMIN_SEED_PASSWORD=CHANGE_ME_min_12_chars

# ─── NuvemPro Partners (comissionamento de parceiros)
# Crie sua API Key em https://partners.nuvempro.com/admin/api-keys
PARTNERS_API_KEY=nv_live_CHANGE_ME

# ─── Redis (opcional)
REDIS_URL=
